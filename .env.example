# -----------------------------------------------------------------------------
# APP BASE URL (Your production domain - used for webhooks and payment redirects)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=https://lipapata.co.ke

# -----------------------------------------------------------------------------
# PAYWAVE EXPRESS CONFIGURATION (For Customer Payments + Creator Payouts)
# -----------------------------------------------------------------------------
# Get your API key from: https://paywavexpress.co.ke -> Settings
PAYWAVE_API_KEY=your_paywave_api_key
# The branded payment page URL assigned to your account
PAYWAVE_PAYMENT_URL=https://paywavexpress.co.ke/pay/lipapata
NEXT_PUBLIC_PAYWAVE_PAYMENT_URL=https://paywavexpress.co.ke/pay/lipapata

# -----------------------------------------------------------------------------
# FIREBASE CONFIGURATION (From Firebase Console)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# -----------------------------------------------------------------------------
# CLOUDINARY CONFIGURATION (For Asset Storage)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# -----------------------------------------------------------------------------
# PAYSTACK CONFIGURATION (For Payments and Payouts)
# -----------------------------------------------------------------------------
PAYSTACK_PUBLIC_KEY=pk_test_e26828dee77ec647ded50e00aace9d7d2af55705
PAYSTACK_SECRET_KEY=sk_test_5e2c3272f08c2c96fd505a652b84c08d88d88ab6

# -----------------------------------------------------------------------------
# M-PESA DARAJA API (Legacy/Optional - Paystack handles this now)
# -----------------------------------------------------------------------------
MPESA_ENVIRONMENT=sandbox

# For Paybill:
MPESA_SHORTCODE=your_paybill_number

# For Buy Goods (Till):
MPESA_STORE_NUMBER=9069216
MPESA_TILL_NUMBER=5931866

# -----------------------------------------------------------------------------
# M-PESA B2C CONFIGURATION (For Admin Payouts)
# -----------------------------------------------------------------------------
# You get these from your Safaricom Developer Portal App
MPESA_B2C_CONSUMER_KEY=your_b2c_consumer_key
MPESA_B2C_CONSUMER_SECRET=your_b2c_consumer_secret

# You get this from the Safaricom Organization portal
MPESA_B2C_SHORTCODE=your_b2c_shortcode
MPESA_INITIATOR_NAME=your_initiator_username
MPESA_SECURITY_CREDENTIAL=your_encrypted_initiator_password

# Webhook URLs
MPESA_B2C_TIMEOUT_URL=https://yourdomain.com/api/admin/payout/timeout
MPESA_B2C_RESULT_URL=https://yourdomain.com/api/admin/payout/result
